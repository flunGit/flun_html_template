{
	"name": "flun-html-template",
	"version": "4.0.3",
	"description": "一个HTML模板工具包，提供开发服务器和模板编译功能，支持自定义标签和快捷输入,变量定义,包含文件引用，帮助开发者模块化处理HTML。",
	"main": "index.js",
	"types": "index.d.ts",
	"scripts": {
		"dev": "node dev-server.js",
		"build": "node compile.js",
		"postinstall": "node copy-files.js 2>&1"
	},
	"keywords": [
		"html",
		"template",
		"server",
		"flun"
	],
	"files": [
		"templates",
		"services",
		"static",
		"customize",
		".env",
		"dev-server.js",
		"dev.js",
		"compile.js",
		"build.js",
		"restoreDefaults.js",
		"index.js",
		"index.d.ts",
		"copy-files.js",
		"f-README.md",
		"f-CHANGELOG.md",
		"LICENSE"
	],
	"type": "module",
	"exports": {
		".": "./index.js"
	},
	"author": "flun <cn@flun.top>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/flunGit/flun_html_template.git"
	},
	"homepage": "https://www.npmjs.com/package/flun-html-template#readme",
	"bugs": {
		"url": "https://github.com/flunGit/flun_html_template/issues"
	},
	"license": "ISC",
	"engines": {
		"node": ">=22.12.0",
		"npm": ">=10.0.0"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"chokidar": "^5.0.0",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.2",
		"express-session": "^1.19.0",
		"flun-env": "^3.1.3",
		"flun-mail": "^2.1.2",
		"flun-webauthn-server": "^2.0.5",
		"mysql2": "^3.20.0",
		"otplib": "^13.4.0",
		"qrcode": "^1.5.4",
		"socket.io": "^4.8.3"
	},
	"overrides": {
		"fast-xml-parser": "^5.3.4"
	},
	"devDependencies": {
		"nodemon": "^3.1.11"
	}
}
